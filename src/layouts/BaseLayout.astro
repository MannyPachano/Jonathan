---
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import MobileCTABar from "../components/MobileCTABar.astro";

/* Preload display face so nav + hero headline paint early (shortens font chain vs parsing CSS first). */
import antonLatinWoff2Url from "@fontsource/anton/files/anton-latin-400-normal.woff2?url";

/* Latin subsets only → fewer / smaller font files vs full family CSS (big TBT/LCP win). */
import "@fontsource/anton/latin-400.css";
import "../styles/bricolage-latin-wght.css";
import "@fontsource/jetbrains-mono/latin-400.css";
import "@fontsource/jetbrains-mono/latin-500.css";
import "@fontsource/jetbrains-mono/latin-700.css";

import "../styles/site.css";

interface Props {
	title: string;
	description: string;
	nav?: "home" | "about" | "teach" | "lessons" | "faq";
	/** Preload the LCP image (e.g. hero on home). Must match a URL the <picture> will request. */
	lcpImage?: { href: string; type?: string };
	/** Where the sticky mobile CTA links. Pages with an on-page booking form pass "#book". */
	bookHref?: string;
}

const { title, description, nav = "home", lcpImage, bookHref = "/lessons#book" } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link
			rel="preload"
			href={antonLatinWoff2Url}
			as="font"
			type="font/woff2"
			crossorigin
		/>
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="theme-color" content="#0E0B14" />

		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
		<link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<link rel="manifest" href="/site.webmanifest" />

		{
			lcpImage && (
				<link
					rel="preload"
					as="image"
					href={lcpImage.href}
					type={lcpImage.type ?? "image/avif"}
					fetchpriority="high"
				/>
			)
		}
	</head>
	<body>
		<a class="skip-link" href="#main">Skip to content</a>
		<Nav current={nav} />
		<main id="main">
			<slot />
		</main>
		<Footer />
		<MobileCTABar bookHref={bookHref} />
		<script defer src="/js/site.js"></script>
	</body>
</html>
